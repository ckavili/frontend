{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Canopy UI Helm Chart Values Schema",
  "description": "Schema for validating values.yaml configuration for the Canopy UI Helm chart",
  "properties": {
    "MODEL_NAME": {
      "type": "string",
      "description": "Name of the model to be used",
      "default": "llama32",
      "minLength": 1
    },
    "LLM_ENDPOINT": {
      "type": "string",
      "description": "Endpoint URL for the LLM service",
      "default": ""
    },
    "BACKEND_ENDPOINT": {
      "type": "string",
      "description": "Endpoint URL for the backend service",
      "default": ""
    },
    "chart_path": {
      "type": "string",
      "description": "Path to the Helm chart in the repository"
    },
    "repo_url": {
      "type": "string",
      "description": "URL of the source repository"
    },
    "MLFLOW_TRACKING_URI": {
      "type": "string",
      "description": "MLflow tracking server URI",
      "examples": [
        "https://mlflow.apps.example.com/mlflow"
      ]
    },
    "MLFLOW_PROMPT_NAME": {
      "type": "string",
      "description": "MLflow prompt registry name to fetch the system prompt",
      "default": "summarization",
      "minLength": 1
    },
    "MLFLOW_PROMPT_VERSION": {
      "type": "string",
      "description": "MLflow prompt version to fetch (alias or number)",
      "default": "latest"
    },
    "image": {
      "type": "object",
      "description": "Container image configuration",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the container image",
          "default": "canopy-ui",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "description": "Tag of the container image",
          "default": "latest",
          "minLength": 1
        }
      },
      "required": ["name", "tag"],
      "additionalProperties": false
    }
  },
  "required": [
    "MLFLOW_TRACKING_URI",
    "MLFLOW_PROMPT_NAME",
    "MODEL_NAME"
  ],
  "additionalProperties": false
}